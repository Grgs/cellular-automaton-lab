{
    "name": "cellular-automaton-lab",
    "private": true,
    "scripts": {
        "build:frontend": "vite build --mode server",
        "build:frontend:server": "vite build --mode server",
        "build:frontend:standalone": "node ./tools/build-standalone.mjs",
        "build:standalone-and-test": "npm run test:e2e:playwright:standalone",
        "dev:frontend": "vite build --watch --mode server",
        "format:frontend": "prettier --write \"frontend/**/*.{ts,d.ts,html}\" \"static/css/**/*.css\" \"templates/**/*.html\" \"vite.config.ts\" \"tools/*.mjs\" \"*.{json,mjs}\"",
        "format:frontend:check": "prettier --check \"frontend/**/*.{ts,d.ts,html}\" \"static/css/**/*.css\" \"templates/**/*.html\" \"vite.config.ts\" \"tools/*.mjs\" \"*.{json,mjs}\"",
        "format:python:check": "node ./tools/run-python.mjs tools/run_python_style.py format-check",
        "lint:frontend": "npm run typecheck:frontend && npm run lint:frontend:eslint && npm run format:frontend:check",
        "lint:frontend:eslint": "eslint \"frontend/**/*.ts\" \"vite.config.ts\"",
        "lint:python": "node ./tools/run-python.mjs tools/run_python_style.py check",
        "typecheck:frontend": "tsc -p tsconfig.json --noEmit",
        "test:frontend": "vitest run",
        "test:e2e:playwright": "node ./tools/run-playwright.mjs --suite all",
        "test:e2e:playwright:server": "node ./tools/run-playwright.mjs --suite server",
        "test:e2e:playwright:subset": "node ./tools/run-playwright.mjs --suite subset",
        "test:e2e:playwright:standalone": "node ./tools/run-playwright.mjs --suite standalone",
        "check:python": "npm run lint:python && npm run format:python:check",
        "check:frontend": "npm run lint:frontend && npm run build:frontend && npm run test:frontend",
        "check:e2e": "npm run typecheck:frontend && npm run build:frontend && npm run test:e2e:playwright",
        "check:ci-local": "npm run check:python && npm run check:frontend && node ./tools/run-python.mjs tools/validate_tilings.py && node ./tools/run-python.mjs tools/verify_reference_tilings.py && npm run test:e2e:playwright",
        "fixtures:reference:check": "node ./tools/run-python.mjs tools/regenerate_reference_fixtures.py --all --mode both --check",
        "audit:supply-chain": "node ./tools/run-python.mjs tools/run_supply_chain_audit.py",
        "coverage:backend": "node ./tools/run-python.mjs tools/run_coverage.py",
        "check:bundle-size": "node ./tools/run-python.mjs tools/check_bundle_size.py",
        "smoke:standalone": "node ./tools/run-python.mjs tools/smoke_test_standalone.py",
        "check:doc-links": "node ./tools/run-python.mjs tools/check_doc_links.py"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.5.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "jsdom": "^29.0.1",
        "polygon-clipping": "^0.15.7",
        "prettier": "^3.8.3",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.10",
        "vitest": "^4.1.2"
    }
}
