{
    "name": "cellular-automaton-lab",
    "private": true,
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build:frontend": "vite build --mode server",
        "build:frontend:server": "vite build --mode server",
        "build:frontend:standalone": "node ./tools/internal/python_tools_entry.mjs build standalone",
        "build:standalone-and-test": "npm run test:e2e:playwright:standalone",
        "dev:frontend": "vite build --watch --mode server",
        "format:frontend": "prettier --write \"frontend/**/*.{ts,d.ts,html}\" \"static/css/**/*.css\" \"templates/**/*.html\" \"vite.config.ts\" \"tools/internal/*.mjs\" \"*.{json,mjs}\"",
        "format:frontend:check": "prettier --check \"frontend/**/*.{ts,d.ts,html}\" \"static/css/**/*.css\" \"templates/**/*.html\" \"vite.config.ts\" \"tools/internal/*.mjs\" \"*.{json,mjs}\"",
        "format:python:check": "node ./tools/internal/python_tools_entry.mjs repo python-style format-check",
        "lint:frontend": "npm run typecheck:frontend && npm run lint:frontend:eslint && npm run format:frontend:check",
        "lint:frontend:eslint": "eslint \"frontend/**/*.ts\" \"vite.config.ts\"",
        "lint:python": "node ./tools/internal/python_tools_entry.mjs repo python-style check",
        "typecheck:frontend": "tsc -p tsconfig.json --noEmit",
        "typecheck:python": "node ./tools/internal/python_exec.mjs -m mypy --config-file pyproject.toml",
        "test:frontend": "vitest run",
        "test:e2e:playwright": "node ./tools/internal/python_tools_entry.mjs test e2e --suite all",
        "test:e2e:playwright:server": "node ./tools/internal/python_tools_entry.mjs test e2e --suite server",
        "test:e2e:playwright:subset": "node ./tools/internal/python_tools_entry.mjs test e2e --suite subset",
        "test:e2e:playwright:standalone": "node ./tools/internal/python_tools_entry.mjs test e2e --suite standalone",
        "check:python": "npm run lint:python && npm run format:python:check && npm run typecheck:python",
        "check:frontend": "npm run lint:frontend && npm run build:frontend && npm run test:frontend",
        "check:e2e": "npm run typecheck:frontend && npm run build:frontend && npm run test:e2e:playwright",
        "check:ci-local": "npm run check:python && npm run check:frontend && node ./tools/internal/python_tools_entry.mjs tilings validate && node ./tools/internal/python_tools_entry.mjs tilings verify && npm run test:e2e:playwright",
        "fixtures:reference:check": "node ./tools/internal/python_tools_entry.mjs fixtures reference --all --mode both --check",
        "audit:supply-chain": "node ./tools/internal/python_tools_entry.mjs security supply-chain",
        "coverage:backend": "node ./tools/internal/python_tools_entry.mjs test coverage --fail-under 75",
        "coverage:frontend": "vitest run --coverage",
        "check:bundle-size": "node ./tools/internal/python_tools_entry.mjs build bundle-size",
        "smoke:standalone": "node ./tools/internal/python_tools_entry.mjs browser smoke-standalone",
        "check:doc-links": "linkinator \"*.md\" \".github/**/*.md\" \"docs/**/*.md\""
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "jsdom": "^29.1.1",
        "linkinator": "7.6.1",
        "match-sorter": "^8.3.0",
        "polygon-clipping": "^0.15.7",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vitest": "^4.1.2"
    }
}
